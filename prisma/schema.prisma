generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  RELATIONSHIP_MANAGER
  SUPERVISOR
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ProductCategory {
  PERSONAL_LOAN
  CREDIT_CARD
  FIXED_DEPOSIT
  HOME_LOAN
  INSURANCE
}

enum CustomerRiskProfile {
  LOW
  MEDIUM
  HIGH
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum LoanStatus {
  ACTIVE
  CLOSED
  DEFAULTED
}

enum CampaignChannel {
  WHATSAPP
  EMAIL
  SMS
  PHONE
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENT
  FAILED
  CANCELLED
}

enum RecommendationStatus {
  DRAFT
  APPROVED
  REJECTED
}

enum MessageStatus {
  DRAFT
  APPROVED
  SENT
  REJECTED
}

enum ConversationRole {
  USER
  ASSISTANT
  SYSTEM
}

enum AuditStatus {
  SUCCESS
  FAILED
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum NotePriority {
  LOW
  MEDIUM
  HIGH
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id           String     @id @default(uuid())
  firstName    String
  lastName     String
  email        String     @unique
  passwordHash String
  role         UserRole   @default(RELATIONSHIP_MANAGER)
  status       UserStatus @default(ACTIVE)
  lastLogin    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  conversations          Conversation[]          @relation("UserConversations")
  auditLogs              AuditLog[]              @relation("UserAuditLogs")
  crmNotes               CrmNote[]               @relation("CrmNoteAuthor")
  productRecommendations ProductRecommendation[] @relation("RecommendedByUser")
  approvedMessages       GeneratedMessage[]      @relation("MessageApprover")

  @@index([email])
  @@index([role])
}

// ─── Customer ──────────────────────────────────────────────────────────────

model Customer {
  id                String              @id @default(uuid())
  customerCode      String              @unique
  firstName         String
  lastName          String
  email             String?
  phone             String?
  occupation        String?
  city              String?
  state             String?
  country           String              @default("India")
  annualIncome      Float
  monthlyIncome     Float
  avgMonthlyBalance Float               @default(0)
  creditScore       Int
  relationshipYears Float
  preferredLanguage String              @default("en")
  preferredChannel  CampaignChannel     @default(WHATSAPP)
  riskProfile       CustomerRiskProfile @default(MEDIUM)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?

  customerProducts       CustomerProduct[]       @relation("CustomerProducts")
  transactions           Transaction[]           @relation("CustomerTransactions")
  loans                  Loan[]                  @relation("CustomerLoans")
  crmNotes               CrmNote[]               @relation("CustomerCrmNotes")
  campaigns              Campaign[]              @relation("CustomerCampaigns")
  productRecommendations ProductRecommendation[] @relation("CustomerRecommendations")
  generatedMessages      GeneratedMessage[]      @relation("CustomerMessages")

  @@index([customerCode])
  @@index([monthlyIncome])
  @@index([creditScore])
  @@index([city])
  @@index([relationshipYears])
  @@index([monthlyIncome, creditScore])
}

// ─── Product ───────────────────────────────────────────────────────────────

model Product {
  id                       String          @id @default(uuid())
  name                     String
  category                 ProductCategory @unique
  description              String?
  interestRate             Float?
  minimumIncome            Float
  minimumCreditScore       Int
  maximumLoanAmount        Float?
  minimumRelationshipYears Float           @default(0)
  active                   Boolean         @default(true)
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
  deletedAt                DateTime?

  customerProducts       CustomerProduct[]       @relation("ProductHoldings")
  productRecommendations ProductRecommendation[] @relation("ProductRecommendations")
}

// ─── CustomerProduct ───────────────────────────────────────────────────────

model CustomerProduct {
  id            String   @id @default(uuid())
  customerId    String
  productId     String
  accountNumber String
  openedDate    DateTime
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer Customer @relation("CustomerProducts", fields: [customerId], references: [id], onDelete: Cascade)
  product  Product  @relation("ProductHoldings", fields: [productId], references: [id])

  @@unique([customerId, productId, accountNumber])
  @@index([customerId])
}

// ─── Transaction ───────────────────────────────────────────────────────────

model Transaction {
  id              String          @id @default(uuid())
  customerId      String
  transactionDate DateTime
  amount          Float
  balance         Float?
  merchant        String?
  category        String?
  transactionType TransactionType
  description     String?
  createdAt       DateTime        @default(now())

  customer Customer @relation("CustomerTransactions", fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([transactionDate])
  @@index([category])
  @@index([customerId, transactionDate])
}

// ─── Loan ──────────────────────────────────────────────────────────────────

model Loan {
  id              String          @id @default(uuid())
  customerId      String
  loanType        ProductCategory
  loanAmount      Float
  interestRate    Float
  remainingAmount Float
  emiAmount       Float
  status          LoanStatus      @default(ACTIVE)
  missedPayments  Int             @default(0)
  startDate       DateTime
  endDate         DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  customer Customer @relation("CustomerLoans", fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([status])
}

// ─── CRMNote ───────────────────────────────────────────────────────────────

model CrmNote {
  id           String       @id @default(uuid())
  customerId   String
  createdById  String?
  sentiment    Sentiment    @default(NEUTRAL)
  priority     NotePriority @default(MEDIUM)
  followUpDate DateTime?
  note         String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  customer  Customer @relation("CustomerCrmNotes", fields: [customerId], references: [id], onDelete: Cascade)
  createdBy User?    @relation("CrmNoteAuthor", fields: [createdById], references: [id])

  @@index([customerId])
  @@index([priority])
}

// ─── Campaign ──────────────────────────────────────────────────────────────

model Campaign {
  id           String          @id @default(uuid())
  customerId   String
  campaignName String
  channel      CampaignChannel
  status       CampaignStatus  @default(DRAFT)
  opened       Boolean         @default(false)
  clicked      Boolean         @default(false)
  converted    Boolean         @default(false)
  sentDate     DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deletedAt    DateTime?

  customer Customer @relation("CustomerCampaigns", fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([sentDate])
  @@index([customerId, sentDate])
}

// ─── ProductRecommendation ─────────────────────────────────────────────────

model ProductRecommendation {
  id              String               @id @default(uuid())
  customerId      String
  productId       String
  conversationId  String?
  conversionScore Float
  confidence      Float
  reason          String[]
  recommendedById String?
  status          RecommendationStatus @default(DRAFT)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  customer     Customer      @relation("CustomerRecommendations", fields: [customerId], references: [id], onDelete: Cascade)
  product      Product       @relation("ProductRecommendations", fields: [productId], references: [id])
  conversation Conversation? @relation("ConversationRecommendations", fields: [conversationId], references: [id])
  user         User?         @relation("RecommendedByUser", fields: [recommendedById], references: [id])

  @@index([customerId])
  @@index([conversationId])
  @@index([customerId, conversionScore])
}

// ─── GeneratedMessage ──────────────────────────────────────────────────────

model GeneratedMessage {
  id              String          @id @default(uuid())
  customerId      String
  promptVersionId String?
  conversationId  String?
  channel         CampaignChannel @default(WHATSAPP)
  message         String
  status          MessageStatus   @default(DRAFT)
  approvedById    String?
  approvedAt      DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  customer      Customer       @relation("CustomerMessages", fields: [customerId], references: [id], onDelete: Cascade)
  promptVersion PromptVersion? @relation("PromptGeneratedMessages", fields: [promptVersionId], references: [id])
  conversation  Conversation?  @relation("ConversationGeneratedMessages", fields: [conversationId], references: [id])
  approvedBy    User?          @relation("MessageApprover", fields: [approvedById], references: [id])

  @@index([customerId])
  @@index([status])
}

// ─── Conversation ────────────────────────────────────────────────────────

model Conversation {
  id           String   @id @default(uuid())
  userId       String
  title        String?
  requestId    String?  @unique
  intent       String?
  status       String   @default("active")
  startedAt    DateTime @default(now())
  lastActivity DateTime @updatedAt
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user                   User                    @relation("UserConversations", fields: [userId], references: [id])
  messages               ConversationMessage[]   @relation("ConversationMessages")
  executionSteps         AgentExecutionStep[]    @relation("ConversationSteps")
  productRecommendations ProductRecommendation[] @relation("ConversationRecommendations")
  generatedMessages      GeneratedMessage[]      @relation("ConversationGeneratedMessages")
  auditLogs              AuditLog[]              @relation("ConversationAuditLogs")

  @@index([userId])
}

model ConversationMessage {
  id             String           @id @default(uuid())
  conversationId String
  role           ConversationRole
  content        String
  createdAt      DateTime         @default(now())

  conversation Conversation @relation("ConversationMessages", fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model AgentExecutionStep {
  id             String   @id @default(uuid())
  conversationId String
  agentName      String
  toolName       String?
  status         String
  input          Json?
  output         Json?
  durationMs     Int?
  error          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversation Conversation @relation("ConversationSteps", fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

// ─── PromptVersion ─────────────────────────────────────────────────────────

model PromptVersion {
  id          String   @id @default(uuid())
  name        String
  version     String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  generatedMessages GeneratedMessage[] @relation("PromptGeneratedMessages")

  @@unique([name, version])
}

// ─── AuditLog ──────────────────────────────────────────────────────────────

model AuditLog {
  id             String      @id @default(uuid())
  requestId      String?
  userId         String?
  conversationId String?
  agent          String?
  tool           String?
  action         String
  executionTime  Int?
  status         AuditStatus @default(SUCCESS)
  errorMessage   String?
  createdAt      DateTime    @default(now())

  user         User?         @relation("UserAuditLogs", fields: [userId], references: [id])
  conversation Conversation? @relation("ConversationAuditLogs", fields: [conversationId], references: [id])

  @@index([requestId])
  @@index([executionTime])
  @@index([status])
  @@index([requestId, status])
  @@index([createdAt])
}

// ─── FeatureFlag ───────────────────────────────────────────────────────────

model FeatureFlag {
  id          String   @id @default(uuid())
  key         String   @unique
  enabled     Boolean  @default(false)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
